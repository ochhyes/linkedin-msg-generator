# ── AI Provider ──────────────────────────────────
# "claude" or "openai"
AI_PROVIDER=claude

# Anthropic (required if AI_PROVIDER=claude)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI (required if AI_PROVIDER=openai)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ── Auth ─────────────────────────────────────────
# Hasło(a) dostępu, które rozszerzenie wysyła w nagłówku X-API-Key.
# To NIE jest klucz Anthropic (ten siedzi w ANTHROPIC_API_KEY powyżej i nigdy
# nie opuszcza serwera) — to tylko współdzielony sekret żeby tylko zespół miał
# dostęp do backendu. Lista rozdzielona przecinkami; możesz dać proste, łatwe
# do zapamiętania hasło dla zespołu (np. DreamComeTrue!) albo wiele różnych.
# Dla mocniejszego: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEYS=DreamComeTrue!

# ── Rate Limiting ────────────────────────────────
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW=60

# ── CORS ─────────────────────────────────────────
# JSON list. "*" allows all origins — safe because API-key auth is required.
# Restrict further if you want, e.g.: ["chrome-extension://abcdef..."]
CORS_ORIGINS=["*"]

# ── App ──────────────────────────────────────────
DEFAULT_LANGUAGE=pl
DEFAULT_MAX_CHARS=1000
