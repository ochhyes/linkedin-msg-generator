# ── AI Provider ──────────────────────────────────
# "claude" or "openai"
AI_PROVIDER=claude

# Anthropic (required if AI_PROVIDER=claude)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# OpenAI (required if AI_PROVIDER=openai)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ── Auth ─────────────────────────────────────────
# Comma-separated valid API keys for clients
API_KEYS=dev-test-key-123,another-key-456

# ── Rate Limiting ────────────────────────────────
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW=60

# ── App ──────────────────────────────────────────
DEFAULT_LANGUAGE=pl
DEFAULT_MAX_CHARS=300
